<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>REXZ HUB - Global Admin</title>
    <style>
        :root { --red: #ff003c; --bg: #0a0a0a; --card: #121212; }
        body { background: var(--bg); color: white; font-family: 'Segoe UI', sans-serif; margin: 0; padding: 20px; display: flex; flex-direction: column; align-items: center; }
        .container { background: var(--card); padding: 20px; border-radius: 12px; border: 1px solid var(--red); width: 100%; max-width: 350px; box-shadow: 0 0 15px rgba(255, 0, 60, 0.2); }
        h2 { color: var(--red); text-align: center; margin-top: 0; text-transform: uppercase; font-size: 1.2rem; }
        input { width: 100%; padding: 12px; margin-bottom: 10px; background: #1a1a1a; border: 1px solid #333; color: white; border-radius: 6px; box-sizing: border-box; }
        button { width: 100%; padding: 12px; background: var(--red); border: none; color: white; font-weight: bold; border-radius: 6px; cursor: pointer; transition: 0.2s; }
        #status { font-size: 12px; text-align: center; margin-top: 10px; color: #888; }
        .user-item { display: flex; justify-content: space-between; align-items: center; background: #1a1a1a; padding: 8px 12px; border-radius: 6px; margin-bottom: 8px; border: 1px solid #222; }
    </style>
</head>
<body>

<div class="container">
    <h2>Add Whitelist</h2>
    <input type="text" id="user" placeholder="Username Roblox...">
    <input type="password" id="token" placeholder="GitHub Token">
    <button onclick="updateWhitelist('add')">ADD USER</button>
    <div id="status">Ready</div>

    <div class="list-section">
        <button style="background: #222; margin-top: 15px;" onclick="loadWhitelist()">REFRESH LIST</button>
        <div id="whitelistDisplay"></div>
    </div>
</div>

<script>
    const GIST_ID = "1f86a6cc80af35e8ac7aafb961099ea4";
    const FILE_NAME = "Whislistrexz.json";

    async function loadWhitelist() {
        const display = document.getElementById('whitelistDisplay');
        const status = document.getElementById('status');
        try {
            const res = await fetch(`https://api.github.com/gists/${GIST_ID}`);
            const data = await res.json();
            const content = JSON.parse(data.files[FILE_NAME].content);
            display.innerHTML = "";
            content.forEach(name => {
                display.innerHTML += `
                    <div class="user-item">
                        <span>${name}</span>
                        <button style="width:auto; padding:5px;" onclick="updateWhitelist('remove', '${name}')">Hapus</button>
                    </div>`;
            });
            status.innerText = "List Updated.";
        } catch (e) { status.innerText = "Gagal memuat."; }
    }

    async function updateWhitelist(action, targetUser) {
        const user = targetUser || document.getElementById('user').value.trim();
        const token = document.getElementById('token').value;
        const status = document.getElementById('status');
        if (!user || !token) return alert("Isi Username & Token!");

        try {
            const res = await fetch(`https://api.github.com/gists/${GIST_ID}`);
            const data = await res.json();
            let content = JSON.parse(data.files[FILE_NAME].content);

            if (action === 'add') content.push(user);
            else content = content.filter(u => u !== user);

            const update = await fetch(`https://api.github.com/gists/${GIST_ID}`, {
                method: "PATCH",
                headers: { "Authorization": `token ${token}` },
                body: JSON.stringify({ files: { [FILE_NAME]: { content: JSON.stringify(content, null, 4) } } })
            });

            if (update.ok) { loadWhitelist(); status.innerText = "Success! 😈"; }
        } catch (e) { status.innerText = "Error."; }
    }
    loadWhitelist();
</script>
</body>
</html>
